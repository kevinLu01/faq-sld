# 企业微信配置
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id
WECOM_REDIRECT_URI=https://your-domain.com/login

# 本地开发 mock 登录（true=跳过企业微信OAuth）
WECOM_MOCK_LOGIN=false

# LLM（Ollama 本地）
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=qwen2.5:14b

# OCR 模型路径（可挂载本地已下载的模型）
OCR_MODEL_PATH=ucaslcl/GOT-OCR2_0

# ===== vLLM 本地大模型（需要 NVIDIA GPU + nvidia-docker）=====
# 启动命令：docker-compose --profile llm up -d vllm

# HuggingFace Token（下载私有模型需要，公开模型可留空）
HF_TOKEN=

# 国内加速（可选，加速模型下载）
HF_ENDPOINT=https://hf-mirror.com

# 模型配置
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
VLLM_SERVED_NAME=qwen2.5:14b
VLLM_GPU_UTIL=0.85
VLLM_MAX_LEN=8192

# 后端连接 vLLM（Docker 内网地址）
LLM_BASE_URL=http://vllm:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL_NAME=qwen2.5:14b
