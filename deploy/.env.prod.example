# SLD FAQ 生产环境配置模板
# 使用方式: cp .env.prod.example .env  然后填入实际值

# ─── 数据库 ───────────────────────────────────────────
DB_NAME=sld_faq
DB_USER=sld
DB_PASS=<your-db-password>

# ─── Redis ────────────────────────────────────────────
REDIS_PASS=<your-redis-password>

# ─── MinIO ────────────────────────────────────────────
MINIO_ACCESS_KEY=<your-minio-user>
MINIO_SECRET_KEY=<your-minio-password>

# ─── LLM（通过 tailscale 直连本地 vLLM）──────────────
LLM_BASE_URL=http://100.111.228.50:18000/v1
LLM_API_KEY=EMPTY
LLM_MODEL_NAME=qwen2.5:14b

# ─── OCR（通过 tailscale 直连本地 OCR 服务）──────────
OCR_BASE_URL=http://100.111.228.50:8866

# ─── 企业微信 OAuth ──────────────────────────────────
WECOM_CORP_ID=<your-corp-id>
WECOM_CORP_SECRET=<your-corp-secret>
WECOM_AGENT_ID=<your-agent-id>
WECOM_REDIRECT_URI=https://apid.sldbd.com/login
